# انسخ هذا الملف إلى .env.local (محليًا) أو اضبط المتغيرات في Vercel (للإنتاج)

# كلمة مرور لوحة الأدمن
ADMIN_PASSWORD=change-me

# سر توقيع الجلسة (HMAC) — قيمة عشوائية طويلة
AUTH_SECRET=change-me-to-a-long-random-string

# قاعدة البيانات
# محليًا: اتركها فارغة وسيُستخدم ملف local.db تلقائيًا
# للإنتاج (Turso): ضع رابط libsql والتوكن من لوحة Turso
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-token

# تخزين صور المعالم على Cloudflare R2 (واجهة S3)
# R2_ACCOUNT_ID      : معرّف حساب Cloudflare
# R2_ACCESS_KEY_ID   : من R2 → Manage API Tokens (صلاحية Object Read & Write)
# R2_SECRET_ACCESS_KEY
# R2_BUCKET          : اسم الحاوية (bucket)
# R2_PUBLIC_BASE_URL : رابط الوصول العام للحاوية (فعّل Public access / r2.dev أو نطاق مخصّص)
#                      مثال: https://pub-xxxxxxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
